# UK Management — Caddy reverse proxy
# Replace YOUR_DOMAIN with actual domain
# Caddy automatically obtains and renews Let's Encrypt certificates

{$DOMAIN:localhost} {
	# Frontend SPA
	handle {
		reverse_proxy frontend:80
	}

	# Access-control API (отдельный сервис uk-access-api).
	# Объявлено ДО общего /api/*, чтобы access-роуты шли на access-api,
	# а не на сервис-десковый api. Same-origin → httpOnly cookie web-сессии
	# доходит до device/operator/WS эндпоинтов (§9.6, §13).
	handle /api/v1/access/* {
		reverse_proxy access-api:8080
	}

	# Access-control WebSocket (live-экран охраны, §9.6) — тоже на access-api.
	handle /ws/v1/access/* {
		reverse_proxy access-api:8080
	}

	# API
	handle /api/* {
		reverse_proxy api:8080
	}

	# WebSocket
	handle /ws/* {
		reverse_proxy api:8080
	}

	# Health check
	handle /health {
		reverse_proxy api:8080
	}

	# Security headers
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Content-Security-Policy "default-src 'self'; script-src 'self' https://telegram.org; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' wss: ws:; img-src 'self' data: blob: https:; frame-src https://oauth.telegram.org; frame-ancestors 'self' https://web.telegram.org; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
		-Server
	}

	# Logging
	log {
		output file /data/access.log {
			roll_size 10mb
			roll_keep 3
		}
	}
}
