# TEST-071 — e2e login-flow fixture.
# Скопируйте в tests/e2e/.env и заполните. Файл .env гитом игнорируется.

# Базовый URL фронта под тестом (по умолчанию http://localhost:5173 — `npm run dev`).
# Для прод-edge: https://infrasafe.uz
E2E_BASE_URL=http://localhost:5173

# Учётка менеджера для теста «successful login redirects».
# Создаётся скриптом scripts/seed_e2e_user.py (см. ниже).
E2E_MANAGER_EMAIL=admin@test.com
E2E_MANAGER_PASSWORD=E2eTest!2026

# Реальный telegram_id, уже запустивший бота (цель MFA OTP).
# НЕ оставлять чужой/боевой id. Используется только seed-скриптом.
E2E_MANAGER_TELEGRAM_ID=

# --- Подготовка фикстуры ---
# 1) Засидить пользователя (env выше экспортированы или переданы флагами):
#      docker exec uk-management-bot python scripts/seed_e2e_user.py \
#        --email "$E2E_MANAGER_EMAIL" --password "$E2E_MANAGER_PASSWORD" \
#        --telegram-id "$E2E_MANAGER_TELEGRAM_ID"
# 2) Запустить e2e:
#      cd tests/e2e && npx playwright test
#
# Login требует MFA: тест засчитывает и переход на /uk/dashboard, и появление
# шага ввода OTP. Без этих env-переменных тест «successful login» остаётся
# skipped (suite зелёный), что и видно в отчёте.
