# Пример файла конфигурации для Media Service
# Скопируйте этот файл в .env и заполните реальными значениями

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Channels (private channels for media storage)
CHANNEL_REQUESTS=@uk_media_requests_private
CHANNEL_REPORTS=@uk_media_reports_private
CHANNEL_ARCHIVE=@uk_media_archive_private
CHANNEL_BACKUP=@uk_media_backup_private
# Опциональный канал домена контроля доступа (ANPR/шлагбаум).
# Если не задан — access-загрузка вернёт 503 (остальной сервис работает).
CHANNEL_ACCESS=@uk_media_access_private

# Database Configuration
DATABASE_URL=postgresql://media_user:media_password@localhost:5433/uk_media
DATABASE_ECHO=false

# Application Configuration
DEBUG=false
MAX_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Security (для продакшена)
# ⚠️ ARCH-106 Phase 2: на прод-хостах эти значения приходят из Doppler через
# `doppler run --` (в Doppler они называются MEDIA_SECRET_KEY / MEDIA_API_KEYS /
# MEDIA_BOT_TOKEN / MEDIA_DATABASE_URL), а НЕ из этого файла — там остаются только
# CHANNEL_*, ALLOWED_ORIGINS, DEBUG, LOG_LEVEL и лимиты. Локально — как обычно.
SECRET_KEY=your_secret_key_here_change_in_production

# API-ключи клиентов, comma-separated (обязателен: без него аутентификация невозможна).
# Должен содержать значение MEDIA_API_KEY основного стека (его требует access-api) и,
# если оно задано отдельно, MEDIA_SERVICE_API_KEY (его предпочитает основной api).
MEDIA_API_KEYS=key_for_uk_api,key_for_access_api

# File Types (comma-separated)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,video/mp4,video/mpeg,video/quicktime,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600  # 1 hour in seconds