# UK Management — Production Environment
# Скопировать в .env и заполнить все значения

# ──────── Telegram ────────
BOT_TOKEN=                          # @BotFather → token
BOT_USERNAME=your_bot_username
TELEGRAM_CHANNEL_ID=                # ID канала уведомлений (опционально)
ADMIN_USER_IDS=                     # Telegram ID админов через запятую

# ──────── Database ────────
POSTGRES_DB=uk_management
POSTGRES_USER=uk_bot
POSTGRES_PASSWORD=                  # Сгенерировать: openssl rand -hex 32

# ──────── Redis ────────
REDIS_PASSWORD=                     # Сгенерировать: openssl rand -hex 16
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_PUBSUB_URL=redis://:${REDIS_PASSWORD}@redis:6379/1

# ──────── Security ────────
ADMIN_PASSWORD=                     # Пароль админа (мин. 8 символов)
JWT_SECRET=                         # Сгенерировать: openssl rand -hex 32
INVITE_SECRET=                      # Сгенерировать: openssl rand -hex 32 (ОТДЕЛЬНЫЙ от JWT_SECRET)

# ──────── Frontend ────────
FRONTEND_URL=https://your-domain.com  # URL фронтенда для CORS

# ──────── InfraSafe Webhooks (опционально) ────────
INFRASAFE_WEBHOOK_ENABLED=false
INFRASAFE_WEBHOOK_URL=
INFRASAFE_WEBHOOK_SECRET=

# ──────── Application ────────
DEBUG=false
LOG_LEVEL=INFO
USE_REDIS_RATE_LIMIT=true
