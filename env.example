# ARCH-106 Phase 1 (Doppler cutover): на прод-хостах (profk/infrasafe) секреты этого файла
# (BOT_TOKEN, JWT_SECRET_KEY, ACCESS_*, MEDIA_API_KEY и т.п. для app/api/access-api/migrate/
# resource-api/resource-worker) приходят из Doppler, НЕ из .env — см.
# .claude/skills/uk-deploy/SKILL.md. Для локальной разработки .env всё ещё используется как
# обычно.

# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=-1001234567890

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/uk_management_bot
# For development with SQLite:
# DATABASE_URL=sqlite:///./uk_management_bot.db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Application Configuration
ENVIRONMENT=development  # development, production, testing
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Admin Configuration
ADMIN_USER_IDS=123456789,987654321  # Comma-separated list of admin user IDs

# Localization
DEFAULT_LOCALE=ru  # ru, uz

# Security
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here

# Notification Settings
ENABLE_NOTIFICATIONS=true
NOTIFICATION_CHANNEL_ID=-1001234567890

# File Upload Settings
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600  # seconds

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Testing
TEST_DATABASE_URL=sqlite:///./test.db
TEST_REDIS_URL=redis://localhost:6379/1

# ───────────────────────────────────────────────────────────────────────────
# Access Control (домен uk-access-api, ТЗ §8.2/§9.1/§10.2). Пилот.
# ───────────────────────────────────────────────────────────────────────────
# Обязательные секреты (общего дефолта в коде НЕТ — сервис падает RuntimeError):
#
# ACCESS_SNAPSHOT_SIGNING_SEED — приватный seed Ed25519 подписи offline-snapshot
#   (§8.2). 32 байта в hex (64 hex-символа). Сгенерировать:
#     python -c "import secrets; print(secrets.token_hex(32))"
ACCESS_SNAPSHOT_SIGNING_SEED=replace_with_64_hex_chars_from_secrets_token_hex_32
#
# ACCESS_DEVICE_HMAC_SEED — seed пер-устройственного HMAC device-auth (§9.1).
#   Произвольная высокоэнтропийная строка. Сгенерировать:
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
ACCESS_DEVICE_HMAC_SEED=replace_with_high_entropy_secret_token_urlsafe_48
#
# ACCESS_PHOTO_URL_SECRET — секрет HMAC-подписи короткоживущих signed-URL фото
#   (§11). Произвольная высокоэнтропийная строка. Сгенерировать:
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
ACCESS_PHOTO_URL_SECRET=replace_with_high_entropy_secret_token_urlsafe_48
#
# ACCESS_CODE_SECRET — секрет HMAC-SHA256 одноразовых гостевых кодов (§9.3): в БД
#   хранится только хэш кода. Произвольная высокоэнтропийная строка. Сгенерировать:
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
ACCESS_CODE_SECRET=replace_with_high_entropy_secret_token_urlsafe_48
#
# Backend'ы anti-replay/событий: redis обязателен для много-воркерного прода
# (в docker-compose заданы явно). Локально без Redis можно memory.
ACCESS_NONCE_BACKEND=redis   # memory | redis
ACCESS_EVENT_BROKER=redis    # memory | redis
#
# Swagger /docs и /openapi.json (по умолчанию включены). На проде можно выключить.
ACCESS_ENABLE_DOCS=true
#
# Интеграция с медиа-сервисом (§11, §10.2): фото проезда (номер/обзор) грузятся в
# отдельный канал медиа-сервиса ВНЕ горячего пути решения и отдаются по
# media://-ссылке. Клиент ленивый — access-api стартует и без этих переменных
# (ошибка только при фактической загрузке/отдаче фото).
#   MEDIA_SERVICE_URL — базовый URL медиа-сервиса (в compose-сети — порт 8000);
#   MEDIA_API_KEY     — X-API-Key медиа-сервиса (должен входить в его MEDIA_API_KEYS).
MEDIA_SERVICE_URL=http://media-service:8000
MEDIA_API_KEY=replace_with_media_service_api_key
#
# ── [F-03] Edge / trusted-proxy (ТОЛЬКО прод за edge nginx) ────────────────────
# За edge nginx путь /uk/api/ рерайтится в /api/ (префикс срезан) и TLS терминирует
# edge. Без этих переменных uvicorn строит trailing-slash redirect-Location как
# http://.../api/... — теряет и https, и /uk (credential POST может уйти в чужой
# корневой API по cleartext). Dev/local НЕ задаёт их: пусто → uvicorn доверяет
# только 127.0.0.1 и работает без префикса.
#   FORWARDED_ALLOW_IPS — кому uvicorn доверяет X-Forwarded-*. Задать CIDR docker-
#     сети edge (peer edge-контейнера НЕ статичен, поэтому подсеть, не точный IP):
#     profk = 172.19.0.0/16, infrasafe(105) = 172.20.0.0/16. Не ставить "*".
#     ⚠ ОСОЗНАННЫЙ РИСК (принят владельцем): подсеть /16 доверяет X-Forwarded-* от
#     ЛЮБОГО контейнера в uk-network, не только от edge. На profk uk-network —
#     external/shared, там есть посторонние контейнеры (напр. asset-web) → они
#     теоретически могут спуфить X-Forwarded-Proto/For (влияет и на request.client
#     .host: rate-limit, аудит). Выбран subnet, а не точный IP/выделенная сеть,
#     т.к. edge-IP не пинится (uk-network external, ipam не задан). Ужесточение —
#     отдельной задачей (выделенный ingress-сегмент или pin edge-IP в partner-compose).
#     ⚠ Подсеть uk-network НЕ закреплена ipam.config → при пересоздании сети docker
#     может выдать другой /16, и CIDR молча перестанет матчить (F-03 тихо
#     регрессирует). При смене подсети — обновить это значение.
#   API_ROOT_PATH — внешний префикс, который edge срезал; uvicorn вернёт его в
#     Location/OpenAPI. За /uk-edge = /uk.
# FORWARDED_ALLOW_IPS=172.19.0.0/16
# API_ROOT_PATH=/uk
