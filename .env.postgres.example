# PR-7 (F-01): admin/superuser credentials для контейнера postgres.
# Скопируйте в .env.postgres (не в .env — эти переменные больше не должны быть
# видны app/api/access-api, у них свой env_file: [.env, ./.secrets/roles/.env.<role>]).
#
# Использование: openssl rand -base64 32

POSTGRES_DB=uk_management
POSTGRES_USER=uk_bot
POSTGRES_PASSWORD=change_me

# Настройки производительности initdb (кодировка/collation).
POSTGRES_INITDB_ARGS=--encoding=UTF-8 --lc-collate=C --lc-ctype=C
